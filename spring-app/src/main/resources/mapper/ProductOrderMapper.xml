<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
	PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
	"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ishijima.portfoliobackend.mapper.ProductOrderMapper">

	<resultMap id="ProductOrderResultMap" type="com.ishijima.portfoliobackend.entity.ProductOrder">
		<id property="id" column="id"/>
		<result property="productId" column="product_id"/>
		<result property="quantity" column="quantity"/>
		<result property="note" column="note"/>
		<result property="orderedBy" column="ordered_by"/>
		<result property="createdAt" column="created_at"/>
	</resultMap>

	<insert id="insert" parameterType="com.ishijima.portfoliobackend.entity.ProductOrder" useGeneratedKeys="true" keyProperty="id">
		INSERT INTO product_orders (
			product_id,
			quantity,
			note,
			ordered_by,
			created_at
		) VALUES (
			#{productId},
			#{quantity},
			#{note},
			#{orderedBy},
			#{createdAt}
		)
	</insert>

	<select id="findRecent" resultMap="ProductOrderResultMap">
		SELECT
			id,
			product_id,
			quantity,
			note,
			ordered_by,
			created_at
		FROM product_orders
		ORDER BY created_at DESC, id DESC
		LIMIT 100
	</select>
</mapper>
